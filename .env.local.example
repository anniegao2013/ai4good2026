# AWS credentials (IAM user or role with Bedrock + Neptune access)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Neptune cluster endpoint (without port)
NEPTUNE_ENDPOINT=your-neptune-cluster.cluster-xxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_PORT=8182

# Bedrock region (usually same as AWS_REGION)
BEDROCK_REGION=us-east-1
